# 复制此文件为 .env 并填入真实 Key

# Pexels API Key（免费申请：https://www.pexels.com/api/）
PEXELS_API_KEY=your_pexels_key_here

# Pixabay API Key（免费申请：https://pixabay.com/accounts/register/）
PIXABAY_API_KEY=your_pixabay_key_here

# LLM 配置：默认 DeepSeek，也可换 OpenAI/豆包/Kimi
# DeepSeek：https://platform.deepseek.com/
# 豆包：https://www.volcengine.com/product/doubao
# Kimi：https://platform.moonshot.cn/
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_llm_key_here
LLM_MODEL=deepseek-chat

# DailyHotApi 自部署地址（可选，留空用默认演示站）
# 自部署教程：https://github.com/imsyy/DailyHotApi
DAILYHOT_BASE=https://api.vvhan.com
